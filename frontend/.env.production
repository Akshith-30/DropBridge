# Frontend production environment variables
# These are picked up by Vite at build time (npm run build).
# Set them as Vercel environment variables — do NOT commit real values here.

# Backend API base URL (no trailing slash)
# Example: https://dropbridge-api.onrender.com
VITE_API_BASE_URL=https://your-backend.onrender.com

# WebSocket base URL (wss:// for production)
# Example: wss://dropbridge-api.onrender.com
VITE_WS_URL=wss://your-backend.onrender.com

# TURN server for cross-NAT WebRTC (Metered.ca free tier or similar)
# Get credentials at: https://www.metered.ca/stun-turn
VITE_TURN_URL=turn:your-turn-server.com:80
VITE_TURN_USERNAME=your_turn_username
VITE_TURN_CREDENTIAL=your_turn_credential

# Optional: override P2P timeout in ms (default 20000)
# VITE_P2P_TIMEOUT_MS=20000
