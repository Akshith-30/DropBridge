# Optional local overrides — NOT required for default dev setup.
#
# Default `mvn spring-boot:run` uses application.yml:
#   Postgres: localhost:5432/dropbridge  user/postgres  password/postgres
#   Storage:  backend/uploads/
#
# To override, run with a custom profile file or env vars:
#
#   export SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/dropbridge
#   export SPRING_DATASOURCE_USERNAME=postgres
#   export SPRING_DATASOURCE_PASSWORD=your_password
#   cd backend && mvn spring-boot:run
#
# Production (Render Docker) uses SPRING_PROFILES_ACTIVE=production + Supabase + R2.
# See deploy/env.render.example
