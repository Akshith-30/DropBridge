# Vercel → Project → Settings → Environment Variables (Production)
# Root directory must be: frontend

VITE_API_BASE_URL=https://dropbridge-api.onrender.com
VITE_WS_URL=wss://dropbridge-api.onrender.com

# TURN — required for P2P across different networks (Metered.ca free tier)
VITE_TURN_URL=turn:global.relay.metered.ca:80
VITE_TURN_USERNAME=your_metered_username
VITE_TURN_CREDENTIAL=your_metered_credential
