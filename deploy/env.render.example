# Copy values into Render → dropbridge-api → Environment
# Generate JWT: openssl rand -base64 48

# ── Supabase via Session pooler (recommended for Render) ───────────────────
# Render often cannot reach db.*.supabase.co (IPv6) → "Network unreachable".
# In Supabase: Connect → Session pooler → port 5432 → copy HOST (pooler.supabase.com).
#
# IMPORTANT:
#   - DATABASE_URL must start with jdbc:postgresql:// (NOT postgresql://)
#   - Do NOT embed password in DATABASE_URL — use DB_PASSWORD only
#   - Pooler username is postgres.YOUR_PROJECT_REF (not plain postgres)
DATABASE_URL=jdbc:postgresql://aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
DB_USERNAME=postgres.YOUR_PROJECT_REF
DB_PASSWORD=your_supabase_db_password_only_here

# ── JWT ────────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_openssl_rand_base64_48

# ── Cloudflare R2 ──────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET=dropbridge-files

# ── CORS (exact Vercel production URL, no trailing slash) ─────────────────
FRONTEND_URL=https://your-app.vercel.app

# ── First deploy only — then set to validate and redeploy ───────────────────
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# ── Email (optional — leave unset on Render; do NOT use MAIL_HOST=none) ───
# When ready for Resend, add: MAIL_HOST, MAIL_PORT, MAIL_USERNAME, MAIL_PASSWORD, MAIL_FROM
